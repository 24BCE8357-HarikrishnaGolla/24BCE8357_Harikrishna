use vitBranches;

show tables from vitBranches;
select first_name,department,salary from worker
where department='finance' or salary >= 100000;

select * from worker;
#in operator
select worker_id,first_name,department,salary from worker
where worker_id not in (1,8,5);
#between operator
select * from worker 
where salary not between 140000 and 300000;

SELECT * FROM worker
WHERE salary BETWEEN 100000 AND 500000
AND department NOT IN ('marketing','admin');
select worker_id as RollNo from worker;



CREATE TABLE Worker (
	WORKER_ID INT NOT NULL PRIMARY KEY AUTO_INCREMENT,
	FIRST_NAME CHAR(25),
	LAST_NAME CHAR(25),
	SALARY INT(15),
	JOINING_DATE DATETIME,
	DEPARTMENT CHAR(25)
);
#Like operator and signed operator
select * from worker;

SELECT * FROM worker WHERE first_name LIKE '_i__a_';

select * from worker;

select (salary) from worker where department='finance';
#Union Operation
SELECT salary FROM worker
UNION ALL
SELECT salary FROM worker;


select * from worker;

select worker_id as RollNo from worker;

select distinct(department) from worker;

SELECT worker_id, first_name,
CASE
    WHEN salary > 300000 THEN 'Rich'
    WHEN salary >= 100000 and salary <299999 THEN 'Middle'
    ELSE 'Poor'
END 
AS Status
FROM worker;
select min(salary) from worker where department='admin';
select max(salary) from worker where department='admin';
# View tables
create view minsalaryadmin as select min(salary) from worker where department='finance';

create view maxsalaryadmin as select max(salary) from worker where department='admin';


